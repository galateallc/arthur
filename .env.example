# Kindalive environment variables
# Copy this to .env and fill in your real keys:
#   cp .env.example .env
#   source .env
# NEVER commit .env to the repository — it's in .gitignore.

# Required for live mode — Claude Haiku interprets events
# Get your key at https://console.anthropic.com/
export ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — weather data (free tier, 1000 calls/day)
# Sign up at https://openweathermap.org/api
export OPENWEATHERMAP_API_KEY=your-key-here
