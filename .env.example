# Kindalive environment variables
# Copy this to .env and fill in your real keys:
#   cp .env.example .env
# The web UI auto-loads .env from the repo root, so you don't need to
# `source` it — but the `export` form keeps that possible for the CLI.
# NEVER commit .env to the repository — it's in .gitignore.

# --- Cloud LLM (Claude) ---------------------------------------------
# The default backend. Get your key at https://console.anthropic.com/
export ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Local / OpenAI-compatible LLM ----------------------------------
# Alternative to Claude: any OpenAI-compatible server (Ollama,
# LM Studio, vLLM, OpenAI, OpenRouter). Setting KINDALIVE_LLM_BASE_URL
# selects this backend.
# export KINDALIVE_LLM_BASE_URL=http://localhost:11434/v1
# export KINDALIVE_LLM_MODEL=llama3.1
# Bearer token — only needed for hosted services (OPENAI_API_KEY also works):
# export KINDALIVE_LLM_KEY=your-key-here
# Optional OpenRouter attribution headers:
# export KINDALIVE_LLM_REFERER=https://your-site.example
# export KINDALIVE_LLM_TITLE=Kindalive

# --- Web UI hosting --------------------------------------------------
# Bind host/port for `python3 -m kindalive.expression.web_ui`.
# Use 0.0.0.0 to reach the dashboard from your phone on the same Wi-Fi.
# (Hosting platforms that inject $PORT are also respected.)
# export KINDALIVE_HOST=127.0.0.1
# export KINDALIVE_PORT=8080
